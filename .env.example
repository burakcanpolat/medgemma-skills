# Med-Rehber — Environment Variables
# Copy this file as .env and fill in your values.

# MedGemma API endpoint (default: Modal hosted endpoint)
# MEDGEMMA_ENDPOINT=https://your-deployment.modal.run/v1/chat/completions

# MedGemma model name (default: google/medgemma-1.5-4b-it)
# MEDGEMMA_MODEL=google/medgemma-1.5-4b-it

# OpenRouter API key (for Zed / Cursor users)
# OPENROUTER_API_KEY=sk-or-...

# SSL verification (default: true — set to false only for corporate proxies)
# MEDGEMMA_VERIFY_SSL=true

# HuggingFace token is stored as a Modal secret, NOT in this file.
# To set it up: modal secret create huggingface-token HF_TOKEN=hf_your_token
